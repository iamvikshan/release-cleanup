{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "paths": {
      "@api/*": ["./src/api/*"],
      "@cli/*": ["./src/cli/*"],
      "@core/*": ["./src/core/*"],
      "@helpers/*": ["./src/helpers/*"],
      "@types-app/*": ["./src/types/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
